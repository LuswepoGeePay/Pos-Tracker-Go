# POS System - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real secrets to version control

# Server Configuration
 SERVER_PORT=8050
 ENVIRONMENT=development

# Database Configuration
# Format: username:password@tcp(host:port)/database?charset=utf8mb4&parseTime=True&loc=Local
 DATABASE_URL="root:password@tcp(localhost:3306)/posmaster?charset=utf8mb4&parseTime=True&loc=Local"

# JWT Configuration
# Use a strong, random secret in production (at least 32 characters)
# Generate with: openssl rand -base64 32
 JWT_SECRET="change-this-to-a-secure-random-string-in-production"
 JWT_EXPIRATION_HOURS=24

# Email Configuration (SMTP)
# For Gmail: Use app-specific password https://support.google.com/accounts/answer/185833
 SMTP_HOST="smtp.gmail.com"
 SMTP_PORT=587
 SMTP_USERNAME="your-email@gmail.com"
 SMTP_PASSWORD="your-app-password-or-email-password"
 SMTP_FROM_ADDRESS="noreply@yourdomain.com"
 SMTP_FROM_NAME="POS System"

# SSL/TLS Configuration (Optional)
# Uncomment and set if using HTTPS
#  CERT_FILE="/path/to/certificate.pem"
#  KEY_FILE="/path/to/private-key.pem"

# Logging Configuration
 LOG_FILE="pos_master.log"
 LOG_LEVEL="info"

# Optional: Other SMTP Providers Examples
# SendGrid: smtp.sendgrid.net (port 587)
# AWS SES: email-smtp.region.amazonaws.com (port 587)
# Mailgun: smtp.mailgun.org (port 587)
# Microsoft: smtp.office365.com (port 587)
